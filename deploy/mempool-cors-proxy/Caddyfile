# leaky-sats · mempool CORS 프록시
# HTTPS My Ledger → 이 프록시(HTTPS 또는 Tailscale Serve) → 로컬 mempool HTTP
#
# 환경변수:
#   MEMPOOL_UPSTREAM  기본 http://127.0.0.1:3006  (Umbrel mempool 포트에 맞게)
#   CORS_ORIGIN       기본 *  (프로덕션: https://leaky-sats.vercel.app 권장)

{
	auto_https off
}

:8787 {
	@options method OPTIONS
	handle @options {
		header Access-Control-Allow-Origin {$CORS_ORIGIN:*}
		header Access-Control-Allow-Methods "GET, HEAD, OPTIONS"
		header Access-Control-Allow-Headers *
		header Access-Control-Max-Age "86400"
		header Vary Origin
		respond 204
	}

	handle {
		reverse_proxy {$MEMPOOL_UPSTREAM:http://127.0.0.1:3006} {
			header_up Host {host}
		}
		header Access-Control-Allow-Origin {$CORS_ORIGIN:*}
		header Access-Control-Allow-Methods "GET, HEAD, OPTIONS"
		header Access-Control-Expose-Headers *
		header Vary Origin
	}
}
